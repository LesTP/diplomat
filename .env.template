# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=1234567890:replace-with-bot-token

# Numeric Telegram chat ID for public game messages.
DIPLOMAT_PUBLIC_CHANNEL_ID=-1001234567890

# Numeric Telegram chat ID for operator coaching and review commands.
DIPLOMAT_COACHING_CHANNEL_ID=-1009876543210

# Comma-separated Telegram user IDs allowed to issue operator commands.
DIPLOMAT_OPERATOR_USER_IDS=111111111,222222222

# OpenAI API key used by config/pipeline_smoke.yaml.
OPENAI_API_KEY=sk-replace-with-openai-key

# Optional for smoke testing if using OpenAI-only config.
ANTHROPIC_API_KEY=
